{
  "name": "barbersalonhelp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @barbershop/web",
    "build": "npm run typecheck --workspace @barbershop/shared && npm run build --workspace @barbershop/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
