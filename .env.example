# Frontend (apps/web) — safe to expose to the browser
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Which data layer the web app uses: "mock" (Phase 1) or "supabase" (Phase 2)
VITE_DATA_BACKEND=mock

# Backend (apps/api) — Phase 2, NEVER expose these to the browser
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
API_PORT=4000
