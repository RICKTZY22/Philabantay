# Future backend only — NEVER expose these values through a VITE_ variable.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
API_PORT=4000
WEB_ORIGIN=http://localhost:5174,http://127.0.0.1:5174

# Browser-safe frontend configuration. The service-role key must never use a
# VITE_ prefix. `supabase` remains accepted as an alias for `api`.
VITE_DATA_BACKEND=mock
VITE_API_BASE_URL=http://127.0.0.1:4000/api/v1

# Optional Docker-backed authorization suite. The three LOCAL_ values are
# required only when RUN_LOCAL_SUPABASE_TESTS=1; obtain them from
# `npx supabase status -o env` and keep them in an ignored .env file or the
# current shell, never in source control.
RUN_LOCAL_SUPABASE_TESTS=0
LOCAL_SUPABASE_URL=
LOCAL_SUPABASE_PUBLISHABLE_KEY=
LOCAL_SUPABASE_SECRET_KEY=
