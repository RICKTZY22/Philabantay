SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
API_PORT=4000
# Comma-separated allowlist of the exact browser origin(s) that may call the API.
# Must match the web app's real origin (scheme + host + port).
WEB_ORIGIN=http://localhost:5174,http://127.0.0.1:5174
# Set to "production" when deployed so error responses never leak internals.
NODE_ENV=development

# --- Local demo account seeder (npm run seed:accounts -w @barbershop/api) ---
# LOCAL DEV ONLY. Never commit real values here; .env is gitignored.
# Leave the password vars unset to have strong passwords generated at runtime
# (printed once). Set one shared password, or per-role passwords, to pin them.
# SEED_PASSWORD=
# SEED_OWNER_PASSWORD=
# SEED_BARBER_PASSWORD=
# SEED_CUSTOMER_PASSWORD=
# Optional email overrides (defaults: owner@phila.test / barber@phila.test / customer@phila.test)
# SEED_OWNER_EMAIL=
# SEED_BARBER_EMAIL=
# SEED_CUSTOMER_EMAIL=
# Safety: the seeder refuses non-local SUPABASE_URL unless SEED_ALLOW_REMOTE=true.
# SEED_ALLOW_REMOTE=false
